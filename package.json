{
  "name": "claude-workflows-viz",
  "version": "0.1.0",
  "description": "Render a Claude Code dynamic-workflow file as an SVG/PNG diagram — agent topology statically inferred from the body, never executed",
  "license": "MIT",
  "author": "Oliver Im",
  "type": "module",
  "bin": {
    "claude-workflows-viz": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples",
    "skills"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "regen-examples": "node scripts/build.mjs && node scripts/regen-examples.mjs",
    "capture-grammar": "node scripts/capture-grammar.mjs",
    "check-grammar": "node scripts/capture-grammar.mjs --check",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pretest": "npm run build",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude-code",
    "workflows",
    "dynamic-workflows",
    "diagram",
    "svg",
    "visualization",
    "agents",
    "topology"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oliver-im/claude-workflows-viz.git"
  },
  "homepage": "https://github.com/oliver-im/claude-workflows-viz#readme",
  "bugs": "https://github.com/oliver-im/claude-workflows-viz/issues",
  "dependencies": {
    "@napi-rs/image": "^1.14.0",
    "@resvg/resvg-js": "^2.6.2",
    "acorn": "^8.14.0",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
